{
    "name": "vscode-makrell-omni",
    "displayName": "Makrell Language Family Support",
    "description": "VS Code support for the Makrell family: Makrell, MakrellPy, MakrellTS, Makrell#, MRON, MRML, and MRTD.",
    "version": "0.10.0",
    "publisher": "hchrholm",
    "icon": "images/makrell.png",
    "engines": {
        "vscode": "^1.78.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "keywords": [
        "makrell",
        "makrellpy",
        "makrellts",
        "makrellsharp",
        "mron",
        "mrml",
        "mrtd"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hcholm/makrell-omni.git"
    },
    "bugs": {
        "url": "https://github.com/hcholm/makrell-omni/issues"
    },
    "homepage": "https://makrell.dev/",
    "contributes": {
        "commands": [
            {
                "command": "makrell.server.restart",
                "title": "Restart Makrell Language Server",
                "category": "makrell"
            },
            {
                "command": "makrell.server.executeCommand",
                "title": "Execute Makrell Language Server Command",
                "category": "makrell"
            },
            {
                "command": "makrell.server.startRepl",
                "title": "Start Makrell REPL",
                "category": "makrell"
            },
            {
                "command": "makrell.server.sendToRepl",
                "title": "Send Code to Makrell REPL",
                "category": "makrell"
            },
            {
                "command": "makrell.server.stopRepl",
                "title": "Stop Makrell REPL",
                "category": "makrell"
            },
            {
                "command": "makrell.runCurrentFile",
                "title": "Run Current File",
                "category": "makrell"
            },
            {
                "command": "makrell.python.checkCurrentFile",
                "title": "Check Current MakrellPy File",
                "category": "makrell"
            },
            {
                "command": "makrell.ts.checkCurrentFile",
                "title": "Check Current MakrellTS File",
                "category": "makrell"
            },
            {
                "command": "makrell.ts.emitCurrentFile",
                "title": "Emit JavaScript for Current MakrellTS File",
                "category": "makrell"
            },
            {
                "command": "makrell.sharp.checkCurrentFile",
                "title": "Check Current Makrell# File",
                "category": "makrell"
            },
            {
                "command": "makrell.sharp.buildCurrentFile",
                "title": "Build Current Makrell# File",
                "category": "makrell"
            },
            {
                "command": "makrell.sharp.emitCSharpCurrentFile",
                "title": "Emit C# for Current Makrell# File",
                "category": "makrell"
            },
            {
                "command": "makrell.sharp.runBuiltAssemblyCurrentFile",
                "title": "Run Built Assembly for Current Makrell# File",
                "category": "makrell"
            },
            {
                "command": "makrell.sharp.showMetaSourcesCurrentFile",
                "title": "Show Meta Sources for Current Makrell# File",
                "category": "makrell"
            },
            {
                "command": "makrell.family.parseCurrentMronFile",
                "title": "Parse Current MRON File",
                "category": "makrell"
            },
            {
                "command": "makrell.family.parseCurrentMrmlFile",
                "title": "Parse Current MRML File",
                "category": "makrell"
            },
            {
                "command": "makrell.family.parseCurrentMrtdFile",
                "title": "Parse Current MRTD File",
                "category": "makrell"
            },
            {
                "command": "makrell.openDocs",
                "title": "Open Makrell Docs",
                "category": "makrell"
            },
            {
                "command": "makrell.openRepo",
                "title": "Open Makrell Repository",
                "category": "makrell"
            }
        ],
        "keybindings": [
            {
                "command": "makrell.server.sendToRepl",
                "key": "shift+enter"
            }
        ],
        "languages": [
            {
                "id": "makrell",
                "aliases": [
                    "Makrell",
                    "makrell"
                ],
                "extensions": [
                    ".mr",
                    ".mrx",
                    ".mrpy",
                    ".mrts",
                    ".mrsh"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./images/makrell.png",
                    "dark": "./images/makrell.png"
                }
            },
            {
                "id": "makrell-on",
                "aliases": [
                    "Makrell Object Notation",
                    "MRON",
                    "makrell object notation",
                    "mron"
                ],
                "extensions": [
                    ".mron"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./images/makrell-o.png",
                    "dark": "./images/makrell-o.png"
                }
            },
            {
                "id": "makrell-ml",
                "aliases": [
                    "Makrell Markup Language",
                    "MRML",
                    "makrell markup language",
                    "mrml"
                ],
                "extensions": [
                    ".mrml"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./images/makrell-x.png",
                    "dark": "./images/makrell-x.png"
                }
            },
            {
                "id": "makrell-td",
                "aliases": [
                    "Makrell Tabular Data",
                    "MRTD",
                    "makrell tabular data",
                    "mrtd"
                ],
                "extensions": [
                    ".mrtd"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./images/makrell-o.png",
                    "dark": "./images/makrell-o.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "makrell",
                "scopeName": "source.makrell",
                "path": "./syntaxes/makrell.tmLanguage.json"
            },
            {
                "language": "makrell-on",
                "scopeName": "source.makrell",
                "path": "./syntaxes/makrell.tmLanguage.json"
            },
            {
                "language": "makrell-ml",
                "scopeName": "source.makrell",
                "path": "./syntaxes/makrell.tmLanguage.json"
            },
            {
                "language": "makrell-td",
                "scopeName": "source.makrell",
                "path": "./syntaxes/makrell.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "makrell",
                "path": "./snippets/makrell.code-snippets.json"
            },
            {
                "language": "makrell-on",
                "path": "./snippets/makrell.code-snippets.json"
            },
            {
                "language": "makrell-ml",
                "path": "./snippets/makrell.code-snippets.json"
            },
            {
                "language": "makrell-td",
                "path": "./snippets/makrell.code-snippets.json"
            }
        ],
        "configuration": [
            {
                "type": "object",
                "title": "Makrell Language Server Configuration",
                "properties": {
                    "makrell.server.enabled": {
                        "scope": "window",
                        "type": "boolean",
                        "default": true,
                        "description": "Whether the optional Makrell language server should be started when Makrell family files are opened."
                    },
                    "makrell.server.cwd": {
                        "scope": "resource",
                        "type": "string",
                        "description": "Optional working directory used when launching the Makrell language server."
                    },
                    "makrell.server.command": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrell-family-lsp",
                        "description": "Command used to start the optional Makrell language server."
                    },
                    "makrell.server.args": {
                        "scope": "resource",
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "description": "Additional arguments passed to the optional Makrell language server."
                    },
                    "makrell.trace.server": {
                        "scope": "resource",
                        "type": "string",
                        "default": "off",
                        "enum": [
                            "off",
                            "verbose"
                        ],
                        "description": "Controls if LSP messages sent to and from the optional language server should be logged.",
                        "enumDescriptions": [
                            "Do not log any LSP messages.",
                            "Log all LSP messages sent to and from the language server."
                        ]
                    }
                }
            },
            {
                "type": "object",
                "title": "Makrell Run Commands",
                "properties": {
                    "makrell.run.pythonCommand": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrell",
                        "description": "Command used to run MakrellPy files such as .mrpy."
                    },
                    "makrell.run.tsCommand": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrellts",
                        "description": "Command used to run MakrellTS files such as .mrts."
                    },
                    "makrell.run.sharpCommand": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrellsharp",
                        "description": "Command used to run Makrell# files such as .mrsh."
                    }
                }
            },
            {
                "type": "object",
                "title": "Client Configuration",
                "properties": {
                    "makrell.client.documentSelector": {
                        "scope": "window",
                        "type": "array",
                        "items": {
                            "type": "object"
                        },
                        "default": [
                            {
                                "scheme": "file",
                                "language": "makrell"
                            },
                            {
                                "scheme": "file",
                                "language": "makrell-on"
                            },
                            {
                                "scheme": "file",
                                "language": "makrell-ml"
                            },
                            {
                                "scheme": "file",
                                "language": "makrell-td"
                            }
                        ],
                        "description": "The client uses this to decide which documents the optional language server should handle.",
                        "markdownDescription": "The client uses this to decide which documents the optional language server should handle.\nSee [DocumentSelector](https://microsoft.github.io/language-server-protocol/specifications/lsp/3.17/specification/#documentFilter) in the LSP specification for more details."
                    }
                }
            },
            {
                "type": "object",
                "title": "MakrellPy Diagnostics",
                "properties": {
                    "makrell.python.diagnosticsEnabled": {
                        "scope": "resource",
                        "type": "boolean",
                        "default": true,
                        "description": "Whether the extension should run `makrell check --json` for .mrpy files on open and save."
                    },
                    "makrell.python.command": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrell",
                        "description": "Command used for MakrellPy CLI features such as diagnostics."
                    }
                }
            },
            {
                "type": "object",
                "title": "MakrellTS Diagnostics",
                "properties": {
                    "makrell.ts.diagnosticsEnabled": {
                        "scope": "resource",
                        "type": "boolean",
                        "default": true,
                        "description": "Whether the extension should run `makrellts check --json` for .mrts files on open and save."
                    },
                    "makrell.ts.command": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrellts",
                        "description": "Command used for MakrellTS CLI features such as diagnostics."
                    }
                }
            },
            {
                "type": "object",
                "title": "Makrell# Diagnostics",
                "properties": {
                    "makrell.sharp.diagnosticsEnabled": {
                        "scope": "resource",
                        "type": "boolean",
                        "default": true,
                        "description": "Whether the extension should run `makrellsharp check --json` and family-format checks for .mrsh, .mron, .mrml, and .mrtd files on open and save."
                    },
                    "makrell.sharp.command": {
                        "scope": "resource",
                        "type": "string",
                        "default": "makrellsharp",
                        "description": "Command used for Makrell# and family-format CLI features such as diagnostics."
                    }
                }
            }
        ]
    },
    "main": "./out/extension",
    "scripts": {
        "sync:assets": "node ./scripts/sync-shared-assets.mjs",
        "check:assets": "node ./scripts/check-shared-assets.mjs",
        "vscode:prepublish": "bun run compile",
        "package:vsix": "bunx @vscode/vsce package",
        "verify:release": "bun run compile && bun run package:vsix",
        "compile": "bun run sync:assets && bun run check:assets && bunx tsc --noEmit -p . && bunx esbuild ./src/extension.ts --bundle --packages=bundle --platform=node --format=cjs --outfile=./out/extension.js --external:vscode --sourcemap",
        "watch": "bunx tsc -p . -w"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.6.2",
        "@types/node": "^16.11.6",
        "@types/vscode": "^1.78.0",
        "@typescript-eslint/eslint-plugin": "^5.3.0",
        "@typescript-eslint/parser": "^5.3.0",
        "esbuild": "^0.28.0",
        "eslint": "^8.2.0",
        "typescript": "^5.1.0",
        "vscode-languageclient": "^8.1.0"
    }
}
