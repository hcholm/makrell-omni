{
    "comments": {
        "lineComment": "#",
        "blockComment": [
            "/*",
            "*/"
        ]
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ]
    ],
    "autoClosingPairs": [
        {
            "open": "{",
            "close": "}"
        },
        {
            "open": "[",
            "close": "]"
        },
        {
            "open": "(",
            "close": ")"
        },
        {
            "open": "\"",
            "close": "\"",
            "notIn": [
                "string",
                "comment"
            ]
        }
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ]
    ],
    "autoCloseBefore": ";:.,=}])> \n\t",
    "wordPattern": "(-?\\d+(?:\\.\\d+)?)|([\\p{L}_$][\\p{L}\\p{N}_$:-]*)",
    "indentationRules": {
        "increaseIndentPattern": "^.*(?:\\{|\\[|\\()\\s*$",
        "decreaseIndentPattern": "^\\s*[\\}\\]\\)].*$"
    }
}
