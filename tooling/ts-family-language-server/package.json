{
  "name": "makrell-family-lsp",
  "version": "0.10.0",
  "private": true,
  "description": "TypeScript-based family language server for Makrell, MakrellPy, MakrellTS, Makrell#, MRON, MRML, and MRTD.",
  "type": "module",
  "bin": {
    "makrell-family-lsp": "./dist/server.js"
  },
  "scripts": {
    "build": "bunx tsc -p .",
    "typecheck": "bunx tsc --noEmit -p .",
    "start": "bun run src/server.ts"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.9.3"
  }
}
